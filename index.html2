<!DOCTYPE html>
<html>

<body>
    <div id="header"></div>

    <p class="text-item">First paragraph</p>
    <p class="text-item">Second paragraph</p>
    <p class="text-item">Third paragraph</p>

    <script>

        const items = document.getElementsByClassName("text-item");
        for (let i = 0; i < items.length; i++) {
            items[i].style.color = "red";
        }
    </script>
</body>

</html>
