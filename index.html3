<!DOCTYPE html>
<html>

<body>
    <ul>
        <li>Item 1</li>
        <li>Item 2</li>
        <li>Item 3</li>
        <li>Item 4</li>
        <li>Item 5</li>
    </ul>
    <script>

        const listItems = document.getElementsByTagName("li");
        listItems[2].textContent = "I am the chosen one";
        listItems[2].style.fontSize = "20px";
    </script>
</body>

</html>
